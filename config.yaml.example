server_url: https://headscale.example.com

listen_addr: 0.0.0.0:8080

metrics_listen_addr: 127.0.0.1:9090

noise:
  private_key_path: /var/lib/headscale/noise_private.key

prefixes:
  v4: 100.64.0.0/10

derp:
  server:
    enabled: false

dns:
  magic_dns: true
  base_domain: internal.example.com

log:
  format: text
  level: info

policy:
  mode: database